# ─── Configuração Básica ──────────────────────────────────────────
# Copie este arquivo para .env e preencha com suas credenciais.
# Para múltiplos ambientes, crie .env.dev e .env.qa separados.
# Veja .env.standard.example e .env.connected.example para exemplos detalhados.

# Modo de autenticação: "standard" (browser + MFA) ou "connected-app" (OAuth 2.0 API)
SF_AUTH_MODE=standard

SF_BASE_URL=https://<sua-org>.my.salesforce.com
SF_USERNAME=seu-usuario@exemplo.com
SF_PASSWORD=sua-senha
SF_SECURITY_TOKEN=seu-token

# ─── Apenas para Connected App (SF_AUTH_MODE=connected-app) ──────
# SF_CLIENT_ID=consumer-key-do-connected-app
# SF_CLIENT_SECRET=consumer-secret-do-connected-app