# ─── Modo de Autenticação: Standard App ───────────────────────────
# Usa login via browser + MFA manual. Indicado para sandbox pessoal e POCs.
# Sessão salva em .auth/ e reutilizada por ~1 mês.
# Veja docs/auth-standard-app.md para instruções completas.

SF_AUTH_MODE=standard
SF_BASE_URL=https://<sua-org>.my.salesforce.com
SF_USERNAME=seu-usuario@exemplo.com
SF_PASSWORD=suasenha
