# ─── Modo de Autenticação: Connected App (OAuth 2.0) ──────────────
# Login 100% via API — sem browser, sem MFA. Indicado para CI/CD.
# Necessário criar um Connected App no Salesforce Setup.
# Veja docs/auth-connected-app.md para instruções completas.

SF_AUTH_MODE=connected-app
SF_BASE_URL=https://<sua-org>.my.salesforce.com
SF_USERNAME=seu-usuario@exemplo.com
SF_PASSWORD=suasenha
SF_SECURITY_TOKEN=seutokenseguranca
SF_CLIENT_ID=consumer-key-do-connected-app
SF_CLIENT_SECRET=consumer-secret-do-connected-app
